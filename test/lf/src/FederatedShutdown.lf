target uC {
  platform: Native,
}

reactor Src(id: int = 0) {
  timer t(0sec, 100msec);
  output out: int
  input in: int
  state counter: int = 0
  state validation_counter: int = 0

  reaction(startup) -> out{=
    printf("Hello from Src!\n");
  =}

  reaction(shutdown) {=
    printf("SRC: shutting down validation_counter == %i\n", self->validation_counter);
    validate(self->validation_counter == 30);
  =}

  reaction(t) -> out {=
    printf("setting out = %i\n", self->counter);
    lf_set(out, self->counter++);
  =}

  reaction(in) {=
    printf("SRC: Received message value %i\n", in->value);
    self->validation_counter += 1;

    if (in->value == 20) {
      env->request_shutdown(env, SEC(1));
    }
  =}
}

reactor Dst {
  input in: int
  output out: int
  state validation_counter: int = 0

  reaction(startup) {=
    printf("Hello from Dst!\n");
  =}

  reaction(shutdown) {=
    printf("DST: shutting down validation_counter == %i\n", self->validation_counter);
    validate(self->validation_counter == 31);
  =}

  reaction(in) -> out {=
    printf("DST: Received message value %i\n", in->value);
    self->validation_counter += 1;
    lf_set(out, in->value);
  =}
}

federated reactor {
  r1 = new Src(id=42)
  r2 = new Dst()
  r1.out -> r2.in after 1ms
  r2.out -> r1.in after 1ms
}
