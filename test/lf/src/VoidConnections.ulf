
reactor R1 {
  output out: void 
  timer t(0, 10 msec)
  state cnt: int = 0;

  reaction(startup) {=
    printf("Startup!\n");
  =}

  reaction(t) -> out {=
    printf("Hello from R1 at %ld\n", env->get_elapsed_physical_time(env));
    lf_set(out);
  =}
}


reactor R2 {
    input in: void
    state cnt: int = 0;

    reaction(startup) {=
      printf("Hi from other guy at startup\n");
    =}

    reaction(in) {=
        printf("Got Value %i\n", self->cnt);
        self->cnt++;
    =}

    reaction(shutdown) {=
      printf("Expected 11 got %i\n", self->cnt);
      assert(self->cnt == 11);
    =}
}

@platform("native")
@timeout(100ms)
main reactor {
  r1 = new R1()
  r2 = new R2()
  r1.out -> r2.in
}
