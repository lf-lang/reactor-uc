/** Check that preamble is inherited. Success is just compiling and running. */
target uC

preamble {=
  #include "reactor-uc/reactor-c.h"
=}

reactor A {
  preamble {=
    #define FOO 2
  =}

  reaction(startup) {=
    printf("FOO: %d\n", FOO);
  =}
}

reactor B extends A {
  reaction(startup) {=
    printf("FOO 2: %d\n", FOO);
  =}
}

@platform("native")
main reactor {
  b = new B()
}
