// Source produces a dynamically allocated struct, which it passes to Print. Reference counting
// ensures that the struct is freed.
target uC

import Source, Print from "DelayStruct.lf"

preamble {=
  #include "include/hello.h"
=}

@platform("native")
main reactor {
  s = new Source()
  p = new Print()
  s.out -> p.in
}
