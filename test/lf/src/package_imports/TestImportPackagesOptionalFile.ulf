// Test import syntax where the file name in "<packageName>" is optional,
// for packages resolved from build/lfc_include.
import Count from <test-package>
import TestCount from "../legacy/lib/TestCount.ulf"

@platform("native")
@timeout(3s)
@fast(true)
main reactor {
  count = new Count()
  test = new TestCount(num_inputs=4)
  count.out -> test.in
}
